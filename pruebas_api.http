@url = http://localhost:3000/api

# HTTP para probar las peticiones, yo ya lo he probado y me funciona, te lo dejo Ana por si quieres probarlo.


# health check para ver si el server esta encendido
GET {{url}}/health

###

# registro de usuario nuevo
# OJO: name y lastName son obligatorios
# el codigo de verificacion sale en la consola del servidor
POST {{url}}/user/register
Content-Type: application/json

{
  "name": "Alejandro",
  "lastName": "Garcia",
  "email": "test1@empresa.com",
  "password": "Password123!"
}

###

# validar el email con el codigo de 6 digitos que sale en consola
# hay que poner el accessToken del paso anterior en el header
PUT {{url}}/user/validation
Authorization: Bearer AQUI_TU_TOKEN
Content-Type: application/json

{
  "code": "123456"
}

###

# login normal, devuelve accessToken y refreshToken
POST {{url}}/user/login
Content-Type: application/json

{
  "email": "test1@empresa.com",
  "password": "Password123!"
}

###

# ver perfil del usuario autenticado
GET {{url}}/user
Authorization: Bearer AQUI_TU_TOKEN

###

# rellenar nombre y apellidos (onboarding paso 1)
PUT {{url}}/user/register
Authorization: Bearer AQUI_TU_TOKEN
Content-Type: application/json

{
  "name": "Alejandro",
  "lastName": "Garcia",
  "nif": "12345678A"
}

###

# asociar empresa - en este caso como freelance
PATCH {{url}}/user/company
Authorization: Bearer AQUI_TU_TOKEN
Content-Type: application/json

{
  "isFreelance": true,
  "address": {
    "city": "Madrid",
    "street": "Gran Via"
  }
}

###

# subir logo de la empresa
# este no se puede hacer desde aqui porque es multipart
# usar Thunder Client UI -> Body -> Form -> campo "logo" -> subir imagen
# PATCH {{url}}/user/logo

###

# cambiar contrasena
PUT {{url}}/user/password
Authorization: Bearer AQUI_TU_TOKEN
Content-Type: application/json

{
  "currentPassword": "Password123!",
  "newPassword": "NuevaPassword456!"
}

###

# cerrar sesion (invalida los refresh tokens)
POST {{url}}/user/logout
Authorization: Bearer AQUI_TU_TOKEN

###

# eliminar cuenta, con ?soft=true la deja como "borrada" pero sin eliminar de la BD
DELETE {{url}}/user?soft=true
Authorization: Bearer AQUI_TU_TOKEN
